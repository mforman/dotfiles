{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# Brewfile hash: {{ include "Brewfile.tmpl" | sha256sum }}

echo "Running brew update..."
brew update
brew upgrade

# Fix broken cask state: files present but receipt missing
if ! brew list --cask font-hack-nerd-font &>/dev/null 2>&1; then
  brew install --cask --force font-hack-nerd-font
fi

brew bundle
brew cleanup
{{ end }}
