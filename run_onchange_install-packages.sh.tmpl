{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
sudo apt update

function install {
  which $1 &> /dev/null

  if [ $? -ne 0 ]; then
    echo "Installing: ${1}..."
    sudo apt install -y $1
  else
    echo "Already installed: ${1}"
  fi
}

# Basics
install zsh
install fzf
install zoxide
install ripgrep
install tmux
install jq
install unzip # mason extracts zip-packaged tools (terraform-ls, stylua, etc.)
install gcc # nvim-treesitter (main) compiles parsers from source

# Make zsh the login shell
if [ "$(getent passwd "$USER" | cut -d: -f7)" != "$(command -v zsh)" ]; then
  sudo chsh -s "$(command -v zsh)" "$USER"
fi

curl -sS https://starship.rs/install.sh | sh
curl https://mise.run | sh

# Neovim (latest stable from GitHub releases)
NVIM_VERSION=$(curl -s "https://api.github.com/repos/neovim/neovim/releases/latest" | grep -Po '"tag_name": "\K[^"]*')
tmp=$(mktemp -d)
curl -Lo "$tmp/nvim.tar.gz" "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz"
sudo rm -rf /opt/nvim
sudo tar -xf "$tmp/nvim.tar.gz" -C /opt
sudo ln -sf /opt/nvim-linux-x86_64/bin/nvim /usr/local/bin/nvim
rm -rf "$tmp"

LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
tmp=$(mktemp -d)
curl -Lo "$tmp/lazygit.tar.gz" "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
tar -xf "$tmp/lazygit.tar.gz" -C "$tmp" lazygit
sudo install "$tmp/lazygit" /usr/local/bin
rm -rf "$tmp"

# PowerShell (tarball — MS apt repo lacks it for this Ubuntu; snap broken under WSL)
sudo apt install -y libicu78
if ! which pwsh &> /dev/null; then
  PWSH_VERSION=$(curl -s "https://api.github.com/repos/PowerShell/PowerShell/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
  tmp=$(mktemp -d)
  curl -Lo "$tmp/pwsh.tar.gz" "https://github.com/PowerShell/PowerShell/releases/download/v${PWSH_VERSION}/powershell-${PWSH_VERSION}-linux-x64.tar.gz"
  sudo mkdir -p /opt/microsoft/powershell/7
  sudo tar -xf "$tmp/pwsh.tar.gz" -C /opt/microsoft/powershell/7
  sudo chmod +x /opt/microsoft/powershell/7/pwsh
  sudo ln -sf /opt/microsoft/powershell/7/pwsh /usr/local/bin/pwsh
  rm -rf "$tmp"
fi

# Docker Engine (official apt repo)
if ! which docker &> /dev/null; then
  echo "Installing: docker..."
  sudo install -m 0755 -d /etc/apt/keyrings
  sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
  sudo chmod a+r /etc/apt/keyrings/docker.asc
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
    | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
  sudo apt update
  sudo apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
fi

# Allow non-root docker (takes effect on next login)
if ! id -nG "$USER" | grep -qw docker; then
  sudo usermod -aG docker "$USER"
fi

curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash

# tmux plugins: tpm + catppuccin aren't tpm-managed, so clone them; tpm installs the rest
TPM_DIR="$HOME/.config/tmux/plugins/tpm"
[ -d "$TPM_DIR" ] || git clone --depth 1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
CATPPUCCIN_DIR="$HOME/.config/tmux/plugins/catppuccin/tmux"
[ -d "$CATPPUCCIN_DIR" ] || git clone --depth 1 https://github.com/catppuccin/tmux "$CATPPUCCIN_DIR"
TMUX_PLUGIN_MANAGER_PATH="$HOME/.config/tmux/plugins/" "$TPM_DIR/bin/install_plugins"

# Install mise-managed runtimes
export PATH="$HOME/.local/bin:$PATH"
mise install

# tree-sitter CLI (requires node)
mise exec -- npm install -g tree-sitter-cli
{{ end -}}
