if [ -n "${ZSH_DEBUGRC+1}" ]; then
  zmodload zsh/zprof
fi

# History
HISTSIZE=5000
SAVEHIST=$HISTSIZE
mkdir -p "$XDG_STATE_HOME/zsh"
HISTFILE="$XDG_STATE_HOME/zsh/history"
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_FIND_NO_DUPS

# Completions
{{ if not .isPersonal -}}
fpath=("$ZDOTDIR/completions" $fpath)
{{ end -}}
autoload -Uz compinit
mkdir -p "$XDG_CACHE_HOME/zsh"
compinit -d "$XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION"

# Cache brew prefix once; skip brew-dependent plugins if brew is absent.
if command -v brew &> /dev/null; then
  BREW_PREFIX="$(brew --prefix)"
fi

# less colours (tput requires a TTY; belongs here, not in .shellenv)
export LESS_TERMCAP_so=$(tput bold; tput setaf 6)
export LESS_TERMCAP_se=$(tput rmso; tput sgr0)
export LESS_TERMCAP_mb=$(tput blink; tput setaf 1)
export LESS_TERMCAP_md=$(tput bold; tput setaf 3)
export LESS_TERMCAP_me=$(tput sgr0)
export LESS_TERMCAP_us=$(tput sitm; tput setaf 2)
export LESS_TERMCAP_ue=$(tput ritm; tput sgr0)

# Autosuggest
if [[ -n "$BREW_PREFIX" && -f "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
  ZSH_AUTOSUGGEST_USE_ASYNC=1
fi

# Alias expansion function
globalias() {
   if [[ $LBUFFER =~ '[a-zA-Z0-9]+$' ]]; then
       zle _expand_alias
       zle expand-word
   fi
   zle self-insert
}
zle -N globalias

bindkey " " globalias
bindkey "^ " magic-space
bindkey -M isearch " " magic-space

zvm_after_init() {
  command -v fzf &> /dev/null && source <(fzf --zsh)
}

# vi mode
if [[ -n "$BREW_PREFIX" && -f "$BREW_PREFIX/opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh" ]]; then
  source "$BREW_PREFIX/opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh"
fi

# Lazy load SSH agent
function _load_ssh_agent() {
    if [ -z "$SSH_AUTH_SOCK" ]; then
        eval "$(ssh-agent -s)" > /dev/null
        ssh-add ~/.ssh/{{ .sshSignKey }} 2>/dev/null
    fi
}
autoload -U add-zsh-hook
add-zsh-hook precmd _load_ssh_agent


cls() {
  if [[ "$TERM" == "tmux-256color" && -n "$TMUX" ]]; then
    clear && tmux clear-history
  else
    printf '\33c\e[3J'
  fi
}

tmux-fresh() {
  if [[ -n "$TMUX" ]]; then
    echo "Run from outside tmux — kill-server would terminate this session." >&2
    return 1
  fi
  local dir="$XDG_DATA_HOME/tmux/resurrect"
  tmux kill-server 2>/dev/null
  find "$dir" -name 'tmux_resurrect_*.txt' -mtime +14 -delete 2>/dev/null
  rm -f "$dir/last"
  tmux
}

dotcheck() {
  local drift
  drift=$(chezmoi diff)
  if [[ -n "$drift" ]]; then
    echo "🔀 Drift:"
    echo "$drift"
  else
    echo "✅ No drift"
  fi

  echo ""
  echo "📁 Unmanaged ~/.config dirs:"
  comm -23 \
    <(ls -1d ~/.config/*/ 2>/dev/null | xargs -I{} basename {} | sort) \
    <(chezmoi managed --include=dirs 2>/dev/null | grep '^\.config/' | cut -d/ -f2 | sort -u)
}

cm_add_vim() {
  cp ~/.vim/spell/en.utf-8.add ~/.local/share/chezmoi/.chezmoitemplates/vim/spell
  cp ~/.vim/spell/tex.utf-8.add ~/.local/share/chezmoi/.chezmoitemplates/vim/spell
  cp ~/.vim/UltiSnips/tex.snippets ~/.local/share/chezmoi/.chezmoitemplates/vim/UltiSnips
}

cm_add_nvim() {
  cp ~/.config/nvim/spell/en.utf-8.add ~/.local/share/chezmoi/.chezmoitemplates/vim/spell
  cp ~/.config/nvim/spell/tex.utf-8.add ~/.local/share/chezmoi/.chezmoitemplates/vim/spell
  cp ~/.config/nvim/UltiSnips/tex.snippets ~/.local/share/chezmoi/.chezmoitemplates/vim/UltiSnips
}

# Enable direnv
command -v direnv &> /dev/null && eval "$(direnv hook zsh)"

command -v mise &> /dev/null && eval "$(mise activate zsh)"

# Source aliases last
[ -f "$ZDOTDIR/.zsh_aliases" ] && source "$ZDOTDIR/.zsh_aliases"

{{ if not .isPersonal -}}
[ -f "$ZDOTDIR/expana-db.sh" ] && source "$ZDOTDIR/expana-db.sh"
{{ end -}}

command -v zoxide &> /dev/null && eval "$(zoxide init zsh)"
# Check that the function `starship_zle-keymap-select()` is defined.
# xref: https://github.com/starship/starship/issues/3418
type starship_zle-keymap-select >/dev/null || \
  {
    eval "$(starship init zsh)"
  }

if [ -n "${ZSH_DEBUGRC+1}" ]; then
    zprof
fi
