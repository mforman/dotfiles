alias -g la='ls -A'
alias -g ll='ls -ltAh'

alias -g g=git

alias -g vi=nvim
alias -g vim=nvim

alias -g cm=chezmoi
alias -g bup='brew update && brew upgrade'

alias -g glg='git log --all --graph --decorate'
alias vimdiff='nvim -d'
alias ls='ls --color=auto'
alias wget='wget --hsts-file="$XDG_DATA_HOME/wget-hsts"'

alias -g da='direnv allow'
alias -g dcd='docker compose down'
alias -g dcu='docker compose up -d'
alias -g tf=terraform

alias -g reload!='source $ZDOTDIR/.zshrc'

# Debug zsh startup time
alias zsh_debug="time ZSH_DEBUGRC=1 zsh -i -c exit"
