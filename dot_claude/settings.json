{
  "permissions": {
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "effortLevel": "medium",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart":     [{"hooks": [{"type": "command", "command": "~/.claude/hooks/claude-hook.sh SessionStart"}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "~/.claude/hooks/claude-hook.sh UserPromptSubmit"}]}],
    "Stop":             [{"hooks": [{"type": "command", "command": "~/.claude/hooks/claude-hook.sh Stop"}]}],
    "Notification":     [{"hooks": [{"type": "command", "command": "~/.claude/hooks/claude-hook.sh Notification"}]}],
    "SessionEnd":       [{"hooks": [{"type": "command", "command": "~/.claude/hooks/claude-hook.sh SessionEnd"}]}]
  }
}
