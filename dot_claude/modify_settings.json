#!/bin/bash
# chezmoi modify_ script. Receives the current ~/.claude/settings.json on stdin.
# Forces the durable keys below; passes through everything Claude Code writes at
# runtime (theme, editorMode, effortLevel, skipAutoPermissionPrompt, …) so those
# stop showing up as drift in `chezmoi diff`.

managed=$(cat <<'JSON'
{
  "permissions": {
    "defaultMode": "plan"
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh SessionStart" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh UserPromptSubmit" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh Stop" } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh Notification" } ] }
    ],
    "PostToolUse": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh PostToolUse" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "~/.claude/hooks/claude-hook.sh SessionEnd" } ] }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
JSON
)

current=$(cat)
[ -z "$current" ] && current='{}'

jq -n --argjson cur "$current" --argjson mgd "$managed" '$cur + $mgd'
