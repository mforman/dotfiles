# Sourced by every shell (interactive or not) via ~/.zshenv (zsh) and
# ~/.bashrc/~/.bash_profile (bash on Linux). Exports only — no aliases or
# functions, so it is safe in non-interactive contexts (VS Code tasks,
# `zsh -c '...'`, launchd jobs, IDE process spawners, etc.).

# XDG base dirs — already set by ~/.zshenv for zsh; this fallback is for
# bash on Linux which has no equivalent of .zshenv.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Editor / pager — resolved at exec time so PATH order doesn't matter
export EDITOR=nvim
export VISUAL=nvim
export MANPAGER='nvim +Man!'

# Terminal colour
export CLICOLOR=1
export COLORTERM=truecolor

# If $LESS is unset, Git sets it to FRX. I don't want F or X.
export LESS='R'
# LESS_TERMCAP_* (tput) lives in .zshrc — tput requires a TTY and belongs in interactive config.

# PATH
export PATH=$PATH:/usr/local/sbin
export PATH=$PATH:$HOME/.local/bin
{{ if .isWSL }}
# WSL: open URLs in the Windows browser (wslview shim lives in ~/.local/bin)
export BROWSER=wslview
{{ end -}}

if [[ -d /usr/local/go/bin ]]; then
  export PATH=$PATH:/usr/local/go/bin
  export GOPATH=$HOME/src/go
  export GOBIN=$GOPATH/bin
  export PATH=$PATH:$GOBIN
fi
if [[ -d /usr/local/share/dotnet ]]; then
  [[ -d $HOME/dotnet ]] && export PATH="$PATH:$HOME/dotnet"
  export DOTNET_ROOT=/usr/local/share/dotnet
  [[ -d $HOME/.dotnet/tools ]] && export PATH="$HOME/.dotnet/tools:$PATH"
fi
[[ -d /opt/mssql-tools18/bin/ ]] && export PATH="/opt/mssql-tools18/bin/:$PATH"
[[ -d /opt/homebrew/opt/libpq/bin/ ]] && export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

# XDG redirects for tools that default to $HOME
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"
export PSQLRC="$XDG_CONFIG_HOME/psql/psqlrc"
export LESSHISTFILE="$XDG_STATE_HOME/less/history"
export NODE_REPL_HISTORY="$XDG_STATE_HOME/node_repl_history"
export TS_NODE_HISTORY="$XDG_STATE_HOME/ts_node_repl_history"
export PYTHON_HISTORY="$XDG_STATE_HOME/python_history"  # honored by Python 3.13+ only; no-op below
export CARGO_HOME="$XDG_DATA_HOME/cargo"
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"
[[ -d "$CARGO_HOME/bin" ]] && export PATH="$CARGO_HOME/bin:$PATH"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
export MPLCONFIGDIR="$XDG_CACHE_HOME/matplotlib"
export IPYTHONDIR="$XDG_CONFIG_HOME/ipython"
export JUPYTER_CONFIG_DIR="$XDG_CONFIG_HOME/jupyter"
export AZURE_CONFIG_DIR="$XDG_DATA_HOME/azure"
export PSQL_HISTORY="$XDG_STATE_HOME/psql_history"
export TERMINFO="$XDG_DATA_HOME/terminfo"  # can shadow system db if dir is empty; TERMINFO_DIRS is the safety net
export TERMINFO_DIRS="$XDG_DATA_HOME/terminfo:/usr/share/terminfo"
