{{- $name := promptStringOnce . "name" "Name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $isPersonal := promptBoolOnce . "isPersonal" "Personal machine (non-work)?" -}}
{{- $sshSignKey := promptStringOnce . "sshSignKey" "SSH signing/auth key filename (in ~/.ssh/)" -}}
{{- $workEmail := "" -}}
{{- $workDir := "" -}}
{{- if not $isPersonal }}
{{-   $workEmail = promptStringOnce . "workEmail" "Work email address" }}
{{-   $workDir = promptStringOnce . "workDir" "Work code directory (relative to $HOME, e.g. \"work\")" }}
{{- end }}


{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $isWSL = contains "microsoft" (lower .chezmoi.kernel.osrelease) -}}
{{- end -}}

encryption = "age"
[age]
    identity  = "~/.config/chezmoi/key.txt"
    recipient = "age1seq9gprfjcwgnw4lnvp6vvd6wtqr5m5seemzh8r28y4cznaheuysy4u0y7"

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    workEmail = {{ $workEmail | quote }}
    workDir = {{ $workDir | quote }}
    isPersonal = {{ $isPersonal }}
    sshSignKey = {{ $sshSignKey | quote }}
    isWSL = {{ $isWSL }}

